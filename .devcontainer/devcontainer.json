{
    "name": "alk-stack-dev",
    "dockerComposeFile": [
        "../docker-compose.yml",
        "docker-compose.yml"
    ],
    "service": "devcontainer",
    "runServices": [
        "mongo",
        "backend",
        "frontend",
        "devcontainer"
    ],
    "workspaceFolder": "/workspaces/alk-stack",
    "shutdownAction": "stopCompose",
    "overrideCommand": true,
    "forwardPorts": [
        4200,
        8080,
        27017
    ],
    "postCreateCommand": "cd /workspaces/alk-stack/src/frontend/web && npm install",
    "customizations": {
        "vscode": {
            "extensions": [
                "ms-dotnettools.csharp",
                "angular.ng-template",
                "ms-azuretools.vscode-docker",
                "github.vscode-github-actions",
                "humao.rest-client",
                "mongodb.mongodb-vscode",
                "ms-dotnettools.csdevkit",
                "ms-dotnettools.vscode-dotnet-runtime"
            ]
        }
    }
}