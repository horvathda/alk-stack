{
    "name": "alk-stack-dev",
    "dockerComposeFile": [
        "../docker-compose.yml",
        "docker-compose.yml"
    ],
    "service": "devcontainer",
    "workspaceFolder": "/workspaces/alk-stack",
    "shutdownAction": "stopCompose",
    "forwardPorts": [
        4200,
        8080,
        27017
    ],
    "postCreateCommand": "cd /workspaces/alk-stack/src/frontend/web && npm install",
    "customizations": {
        "vscode": {
            "extensions": [
                "ms-dotnettools.csharp",
                "angular.ng-template",
                "ms-azuretools.vscode-docker",
                "github.vscode-github-actions",
                "humao.rest-client",
                "mongodb.mongodb-vscode"
            ]
        }
    },
    "features": {
        "ghcr.io/devcontainer-config/features/dot-config:4": {}
    }
}